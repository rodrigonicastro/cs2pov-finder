# Backend
# Local:
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cs2_pov_notifier
# Azure Database for PostgreSQL (SSL required — append ?ssl=require):
# DATABASE_URL=postgresql+asyncpg://user:password@your-server.postgres.database.azure.com:5432/cs2_pov_notifier?ssl=require
CORS_ORIGINS=http://localhost:5173
# Azure (set to your frontend hostname, comma-separated if multiple):
# CORS_ORIGINS=https://your-frontend.azurestaticapps.net

# Frontend (create frontend/.env.local for dev, or set in Azure build config)
VITE_API_BASE=http://127.0.0.1:8000
# Azure:
# VITE_API_BASE=https://your-api.azurewebsites.net

SKYBOX_API_TOKEN=

YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_IDS=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CS2 POV Finder <your@email.com>
